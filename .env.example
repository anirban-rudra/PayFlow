POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-local-password
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-local-password
JWT_SECRET=replace-with-at-least-32-characters-of-random-secret
INTERNAL_API_KEY=replace-with-a-long-random-service-to-service-secret
GATEWAY_REQUEST_KEY=replace-with-a-long-random-gateway-to-service-secret
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000
REWARD_POINTS_RATE=0.05
REWARD_MINIMUM_AMOUNT=5.00
KAFKA_RETRY_INTERVAL_MS=1000
KAFKA_RETRY_MAX_ATTEMPTS=3
